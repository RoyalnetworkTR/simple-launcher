<UserControl x:Class="OfflineMinecraftLauncher.Pages.NewsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Haberler &amp; Sürüm Notları" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel x:Name="NewsList"/>
                <TextBlock x:Name="EmptyLabel" Text="Henüz sürüm notu yok." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
