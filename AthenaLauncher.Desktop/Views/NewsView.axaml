<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OfflineMinecraftLauncher.Views.NewsView">
    <ScrollViewer>
        <StackPanel Spacing="14" MaxWidth="760">
            <TextBlock Text="Haberler / Sürüm Notları" Classes="title" />
            <StackPanel x:Name="List" Spacing="10" />
            <TextBlock x:Name="Empty" Classes="muted" Text="Yükleniyor..." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
